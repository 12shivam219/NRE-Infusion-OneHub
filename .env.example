
# ==============================================================================
# FRONTEND ENVIRONMENT VARIABLES (Safe - Bundled into client-side code)
# ==============================================================================

# Supabase Configuration (Public - Anon Key)
# Get these values from your Supabase project dashboard:
# 1. Go to https://app.supabase.com
# 2. Select your project
# 3. Go to Settings > API
# 4. Copy the Project URL and Anon Key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google OAuth Configuration (Public - Client ID only)
# To enable Google Integration:
# 1. Create a project in Google Cloud Console
# 2. Enable the Google Drive API and Gmail API
# 3. Create OAuth 2.0 credentials (Web Application)
# 4. Set authorized redirect URIs to http://localhost:5173/oauth/callback
# 5. Copy the Client ID below
# SECURITY: Client Secret is NEVER sent to frontend - handled by backend only
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/callback

# Application URLs
VITE_APP_URL=http://localhost:5173

# Email Server Configuration
VITE_EMAIL_SERVER_URL=http://localhost:3001
VITE_EMAIL_SERVER_API_KEY=your_email_server_api_key

# Sentry Error Tracking (Optional)
# Get your DSN from: https://sentry.io/
# Only set this to enable production error tracking
# Format: https://your-key@sentry.io/your-project-id
VITE_SENTRY_DSN=

# Application Version (for Sentry releases)
VITE_APP_VERSION=0.0.1

# NOTE: Do NOT store secret encryption keys in frontend environment variables.
# Frontend variables prefixed with `VITE_` are bundled into the browser and are
# publicly visible. Move all secret keys to the backend (see ENCRYPTION_MASTER_KEY below).

# ==============================================================================
# EMAIL SERVER CONFIGURATION
# ==============================================================================

# Server Port
EMAIL_SERVER_PORT=3001
NODE_ENV=development

# Email Account Configuration
# Format: email1@gmail.com:app_password1;email2@gmail.com:app_password2
# For Gmail App Passwords: https://support.google.com/accounts/answer/185833
EMAIL_ACCOUNTS=your_email@gmail.com:your_app_password

# Legacy Format (Optional - supports single account fallback)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# CORS Configuration - Whitelist allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# API Key for Email Server Authentication
# Generate with: openssl rand -base64 32
API_KEY=your_random_api_key_here

# Encryption Master Key for Backend Email Server (ENCRYPTION_MASTER_KEY)
# SECURITY CRITICAL: Used for encrypting email passwords on the backend
# In development: Use the default development key (will show a warning)
# In production: MUST be set to a strong, unique key - application will FAIL to start without it
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED: Do not leave empty in production deployments!
ENCRYPTION_MASTER_KEY=your_backend_master_encryption_key_here

# ==============================================================================
# BACKEND SECRETS (Backend-only - NEVER expose to frontend)
# ==============================================================================

# Supabase Service Role Configuration (Used by Supabase Edge Functions)
# These values are provided automatically when deploying via Supabase CLI.
# If invoking functions locally, ensure they are set in your environment.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_URL=https://your-project.supabase.co

# Google OAuth Secret - KEEP THIS SECRET, NEVER EXPOSE TO CLIENT
# Only used on backend for secure token exchange
# Do NOT prefix with VITE_ - it will be bundled into frontend if you do!
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Database Connection (if using separate database)
DATABASE_URL=postgresql://user:password@host:5432/database

# ==============================================================================
# PHASE 1: JOB EXTRACTION & REMOTE FILTERING
# ==============================================================================

# Groq LLM API for Job Extraction
# Get API key from: https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_JOB_EXTRACTION_TEMPERATURE=0.3
GROQ_JOB_EXTRACTION_MAX_TOKENS=2000

# Job Extraction Configuration
JOB_POLLING_INTERVAL_MINUTES=10
EXTRACT_JOBS_MIN_CONFIDENCE=75
EXTRACT_ONLY_100_PERCENT_REMOTE=true
DUPLICATE_CHECK_ENABLED=true

# Scheduler Configuration
START_SCHEDULER_IN_PROCESS=true
START_JOB_EXTRACTION_SCHEDULER=false

# ==============================================================================
# PHASE 2: VECTOR EMBEDDINGS, RAG & SEMANTIC SEARCH
# ==============================================================================

# OpenAI API for Embeddings (Phase 2 only)
# Get API key from: https://platform.openai.com/
# REQUIRED for Phase 2 to work (vector search, RAG recommendations)
OPENAI_API_KEY=sk_your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=1536

# Redis Configuration (for embedding cache and job queues)
# For local dev: redis://localhost:6379
# For managed Redis: redis://:password@hostname:port
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Phase 2 Feature Flags
USE_JOB_EXTRACTION_V3=false
GENERATE_EMBEDDINGS_REAL_TIME=false

# Embedding Service Configuration
EMBEDDING_SERVICE_URL=http://localhost:3001
EMBEDDING_BATCH_SIZE=10
EMBEDDING_CONCURRENCY=3
EMBEDDING_CACHE_TTL_MINUTES=1440

# Vector Search Thresholds
# - RECOMMENDATION (0.70): Show jobs with 70%+ similarity
# - DUPLICATE (0.85): Detect as duplicate if 85%+ similar
SIMILARITY_THRESHOLD_RECOMMENDATION=0.70
SIMILARITY_THRESHOLD_DUPLICATE=0.85

# Embedding Strategy
# Options: 'openai' (production-grade), 'local' (offline fallback)
EMBEDDING_STRATEGY=openai

# ==============================================================================
# DEPLOYMENT & ADVANCED CONFIGURATION
# ==============================================================================

# Job Extraction Agent Version
# v2 = Phase 1 (basic filtering, dedup)
# v3 = Phase 2 (includes real-time embeddings, RAG)
USE_JOB_EXTRACTION_V3=false

# Feature Flags
FEATURE_AUTO_REFRESH_JOBS=true
FEATURE_EMAIL_SYNC=true
FEATURE_JOB_EXTRACTION=true
FEATURE_VECTOR_SEARCH=false
FEATURE_RAG_RECOMMENDATIONS=false
FEATURE_SKILL_MATCHING=false
FEATURE_MARKET_ANALYTICS=false

# Logging
LOG_LEVEL=info
DEBUG=nre-infusion:*

# ==============================================================================
# SETUP INSTRUCTIONS
# ==============================================================================
#
# PHASE 1 MINIMUM SETUP:
# 1. Set: GROQ_API_KEY, GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, ENCRYPTION_MASTER_KEY
# 2. Run: supabase migration deploy (includes 046_ai_agent_system.sql)
# 3. Start: npm run dev
#
# PHASE 2 ADDITIONAL SETUP:
# 1. Set: OPENAI_API_KEY, REDIS_HOST, REDIS_PORT
# 2. Run: supabase migration deploy (includes 047_vector_embeddings_rag.sql)
# 3. Enable: USE_JOB_EXTRACTION_V3=true, GENERATE_EMBEDDINGS_REAL_TIME=true
# 4. Start: npm run dev
#
# DATABASE MIGRATIONS:
# - 046_ai_agent_system.sql (Phase 1) - Job extraction schema
# - 047_vector_embeddings_rag.sql (Phase 2) - Vector embeddings, RAG search
#
# DEPLOYMENT CHECKLIST:
# ✓ All required API keys configured
# ✓ Redis connection active
# ✓ Supabase migrations applied
# ✓ ENCRYPTION_MASTER_KEY set (production)
# ✓ ALLOWED_ORIGINS configured for your domain
# ✓ Environment set to 'production' or 'staging'
